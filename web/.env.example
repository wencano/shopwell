# Supabase — Dashboard → Settings → API Keys
# New keys: https://supabase.com/docs/guides/getting-started/api-keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Publishable (preferred): sb_publishable_... — replaces legacy “anon” JWT
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy anon JWT (only if your project has not migrated to publishable keys yet)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Secret (preferred): sb_secret_... — server-only; replaces legacy service_role JWT
SUPABASE_SECRET_KEY=sb_secret_...
# Legacy service_role JWT (seed / admin API only, until you use a secret key)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Postgres (Supabase → Settings → Database → URI; use pooler + sslmode=require as needed)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# App URL (Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Seed script default password for demo users
# SEED_USER_PASSWORD=ShopwellDemo2026!

# Email (optional)
# RESEND_API_KEY=re_...
